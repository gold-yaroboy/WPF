<UserControl x:Class="CustomTextBoxControl.View.UserControls.ClearableTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CustomTextBoxControl.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="250"
             FontSize="22">
    <Grid Background="AliceBlue">
        <TextBox    Name="txtInput"
                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
            />
        <TextBlock  Name="tbPlacholder" Text="Placeholder"
                    FontWeight="Light" Foreground="DarkGray"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Panel.ZIndex="-1"
            />
        <Button     Name="btnClear"
                    Width="40" HorizontalAlignment="Right" 
                    Content="⮾" FontSize="24" 
                    Background="Transparent" Foreground="DarkGray" BorderThickness="0"
                    Click="btnClear_Click"
            />
    </Grid>
</UserControl>
